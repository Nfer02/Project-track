generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum Plan {
  FREE
  PRO
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum SubscriptionStatus {
  ACTIVE
  INACTIVE
  PAST_DUE
  CANCELLED
}

enum InvoiceType {
  INCOME
  EXPENSE
}

// ─── Models ─────────────────────────────────────────────────────────────────

model User {
  id        String   @id // UUID de Supabase Auth
  email     String   @unique
  name      String?
  avatarUrl String?
  createdAt DateTime @default(now())

  memberships WorkspaceMember[]
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      Plan     @default(FREE)
  createdAt DateTime @default(now())

  members      WorkspaceMember[]
  projects     Project[]
  invoices     Invoice[]
  subscription Subscription?
}

model WorkspaceMember {
  id          String     @id @default(cuid())
  userId      String?    // null mientras la invitación está pendiente
  workspaceId String
  role        MemberRole @default(MEMBER)
  inviteEmail String?
  inviteToken String?    @unique
  acceptedAt  DateTime?
  createdAt   DateTime   @default(now())

  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
}

model Project {
  id          String        @id @default(cuid())
  workspaceId String
  name        String
  clientName  String?
  description String?
  status      ProjectStatus @default(ACTIVE)
  projectValue     Decimal?      @db.Decimal(12, 2)
  budget           Decimal?      @db.Decimal(12, 2)
  currency         String        @default("EUR")
  paymentMethod    String?
  numberOfPayments Int?
  startDate        DateTime?
  endDate          DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invoices  Invoice[]
  isDeclared Boolean @default(true)
  expenseAllocations ExpenseAllocation[]
}

model Invoice {
  id          String        @id @default(cuid())
  type        InvoiceType   @default(INCOME)
  workspaceId String
  projectId   String?
  number      String
  description String?
  amount      Decimal       @db.Decimal(12, 2)
  currency    String        @default("EUR")
  isDeclared  Boolean       @default(true)
  vendorName  String?
  category    String?
  issueDate   DateTime
  dueDate     DateTime?
  paidDate    DateTime?
  status      InvoiceStatus @default(PENDING)
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace   Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project     Project?           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  files       InvoiceFile[]
  allocations ExpenseAllocation[]

  @@unique([workspaceId, type, number])
}

model ExpenseAllocation {
  id        String   @id @default(cuid())
  invoiceId String
  projectId String
  amount    Decimal  @db.Decimal(12, 2)
  notes     String?
  createdAt DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([invoiceId, projectId])
}

model InvoiceFile {
  id          String   @id @default(cuid())
  invoiceId   String
  storagePath String
  filename    String
  mimeType    String
  sizeBytes   Int
  ocrData     Json?
  createdAt   DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Subscription {
  id               String             @id @default(cuid())
  workspaceId      String             @unique
  stripeCustomerId String?            @unique
  stripeSubId      String?            @unique
  stripePriceId    String?
  status           SubscriptionStatus @default(INACTIVE)
  currentPeriodEnd DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}
